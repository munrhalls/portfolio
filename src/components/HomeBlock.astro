---
interface Props {
  href: string;
  title: string;
  description: string;
  class?: string;
}

const { href, title, description, class: className } = Astro.props;
---

<a 
  href={href}
  class:list={["block p-6 transition-all duration-200 hover:bg-[#fafafa] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#222]", className]}
>
  <h2 class="text-xl font-semibold mb-2">{title}</h2>
  <p class="text-gray-600">{description}</p>
</a>
