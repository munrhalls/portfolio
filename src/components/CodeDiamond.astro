---
// src/components/CodeDiamond.astro
---

<div
  class="absolute z-0 pointer-events-none opacity-[0.2] aspect-square w-[90vw] max-w-none right-[-15vw] top-1/2 -translate-y-1/2"
  aria-hidden="true"
>
  <div class="cd-clip">
    <div class="cd-bg" id="cd-bg">
      <div class="cd-overlay"></div>
    </div>
  </div>

  <!-- Static outer ring on top -->
  <img
    src="/images/code-diamond-outer-ring.png"
    alt=""
    class="absolute inset-0 w-full h-full object-contain"
  />
</div>

<style is:global>
  /* ── Container & clip ──────────────────────────────────────────── */
  .cd-clip {
    position: absolute;
    inset: 0;
    overflow: hidden;
    clip-path: polygon(50% 1.4%, 98.5% 50%, 50% 98.5%, 1.4% 50%);
  }

  .cd-bg {
    position: absolute;
    inset: 0;
    background: rgb(10, 12, 28);
    overflow: hidden;
  }

  /* ── Base column (shared by all tiers) ────────────────────────── */
  .cd-col {
    position: absolute;
    top: 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    white-space: nowrap;
    font-family: 'Noto Sans JP', 'Hiragino Kana', 'Yu Gothic', sans-serif;
    animation: cd-scroll var(--dur) linear infinite;
    animation-delay: var(--delay);
    will-change: transform;
  }

  @keyframes cd-scroll {
    from { transform: translateY(-50%); }
    to   { transform: translateY(0%); }
  }

  /* ── Variable-length streams ──────────────────────────────────── */
  .cd-fade {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .cd-fade-s {
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 38%, transparent 54%);
            mask-image: linear-gradient(to bottom, #000 0%, #000 38%, transparent 54%);
  }
  .cd-fade-m {
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 48%, transparent 65%);
            mask-image: linear-gradient(to bottom, #000 0%, #000 48%, transparent 65%);
  }
  .cd-fade-l {
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 60%, transparent 77%);
            mask-image: linear-gradient(to bottom, #000 0%, #000 60%, transparent 77%);
  }
  .cd-fade-band {
    -webkit-mask-image: linear-gradient(to bottom, transparent 40%, #000 56%, #000 74%, transparent 90%);
            mask-image: linear-gradient(to bottom, transparent 40%, #000 56%, #000 74%, transparent 90%);
  }

  /* ── Tier 3: FAR — distant, small, cool, very slow ───────────── */
  .cd-far {
    font-size: max(2.65px, 0.573vw); /* 11px @1920; px floor only nudges small phones larger */
    letter-spacing: 0.12em;
    opacity: .70;
    color: rgb(100, 115, 188);
    text-shadow: 0 0 5px rgba(100, 115, 188, .7);
  }

  /* ── Tier 2: MID — middle distance ────────────────────────────── */
  .cd-mid {
    font-size: max(3.85px, 0.833vw); /* 16px @1920; px floor only nudges small phones larger */
    letter-spacing: 0.22em;
    opacity: .65;
    color: rgb(150, 165, 230);
    text-shadow:
      0 0 9px  rgba(150, 165, 230, .9),
      0 0 20px rgba(115, 138, 215, .42);
  }

  /* ── Tier 1: NEAR — foreground, large, vivid, fast ────────────── */
  .cd-near {
    font-size: max(5.5px, 1.198vw); /* 23px @1920; px floor only nudges small phones larger */
    letter-spacing: 0.30em;
    opacity: 1;
    color: rgb(200, 212, 255);
    text-shadow:
      0 0 10px rgba(200, 212, 255, 1),
      0 0 24px rgba(162, 183, 255, .68),
      0 0 46px rgba(102, 132, 245, .28);
  }

  /* ── Gradient overlay ──────────────────────────────────────────── */
  .cd-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgb(10, 12, 28)        0%,
      rgba(10, 12, 28, 0.88) 12%,
      rgba(10, 12, 28, 0.65) 28%,
      rgba(10, 12, 28, 0.30) 48%,
      rgba(10, 12, 28, 0.05) 65%,
      transparent            80%
    );
    pointer-events: none;
    z-index: 10;
  }
</style>

<script is:inline>
(function(){
  var pool="アクセスデータコードシステムマトリクスネットフローラインメモリスタックバッファポインタアルゴリズムプログラムストリームシグナルベクターモジュールインデックスコンパイラデバッグランタイムカーネルプロセスソケット";
  function span(start){var s=pool.slice(start)+pool.slice(0,start);var one=s.repeat(2).slice(0,30);return one+"　"+one+"　";}
  var cfg=[
    ['far',14,160,-50,'l'],['far',17,165,-42,''],['far',23,150,-95,'s'],['far',29,152,-68,'m'],['far',33,158,-15,'band'],['far',46,156,-22,'m'],['far',59,147,-88,'s'],['far',67,163,-77,''],['far',71,161,-35,''],['far',78,154,-57,''],
    ['mid',27,92,-14,''],['mid',31,90,-40,'l'],['mid',36,86,-58,''],['mid',46,94,-32,'l'],['mid',56,88,-72,''],['mid',66,96,-44,'band'],['mid',70,84,-66,''],['mid',75,82,-28,''],
    ['near',41,60,-8,''],['near',52,56,-38,''],['near',63,64,-22,'']
  ];
  var bg=document.getElementById('cd-bg');
  cfg.forEach(function(c,i){
    var tier=c[0],left=c[1],dur=c[2],delay=c[3],fade=c[4];
    var col=document.createElement('div');
    col.className='cd-col cd-'+tier;
    col.style.left=left+'%';
    col.style.setProperty('--dur',(dur/3).toFixed(0)+'s');
    col.style.setProperty('--delay',(delay/3).toFixed(0)+'s');
    col.textContent=span((i*7)%pool.length);
    if(fade){var w=document.createElement('div');w.className='cd-fade cd-fade-'+fade;w.appendChild(col);bg.appendChild(w);}
    else{bg.appendChild(col);}
  });
})();
</script>