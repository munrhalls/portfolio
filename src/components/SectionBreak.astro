---
// src/components/SectionBreak.astro
// Chapter-break pattern used between every major page section.
// Desktop: 160px top margin. Mobile: 120px top margin.
// Same visual signature throughout the entire page — 1px rule + C1 chapter marker.

interface Props {
  index: string;   // e.g. "01 / 01"
  title: string;   // e.g. "Professional Checkout System"
}

const { index, title } = Astro.props;
---

<div class="sb">
  <div class="sb-rule"></div>
  <div class="sb-marker">
    <span class="sb-index">{index}</span>
    <span class="sb-title">{title}</span>
  </div>
</div>

<style>
  .sb {
    margin-top: 160px;
    padding: 0 80px;
  }
  .sb-rule {
    height: 1px;
    background: var(--border);
    margin-bottom: 24px;
  }
  .sb-marker {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
  }
  /* C1 treatment for both index and title */
  .sb-index,
  .sb-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    line-height: 1.4;
  }
  .sb-index { color: var(--t-muted); }
  .sb-title { color: var(--t-amber); }

  @media (max-width: 767px) {
    .sb {
      margin-top: 120px;
      padding: 0 24px;
    }
    .sb-marker { margin-bottom: 40px; }
  }
</style>
