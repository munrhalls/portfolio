---
interface Props {
  title: string;
  description: string;
  reversed?: boolean;
  id?: string;
}

const { title, description, reversed = false, id } = Astro.props;
---

<section
  id={id}
  class:list={[
    "flex flex-col gap-8 py-16 px-4 md:px-8 scroll-mt-20",
    reversed ? "md:flex-row-reverse" : "md:flex-row",
    "md:items-center md:gap-12",
  ]}
>
  <div class="w-full md:w-1/2">
    <slot name="visual" />
  </div>
  <div class="w-full md:w-1/2">
    <h2 class="text-2xl font-bold mb-4">{title}</h2>
    <p class="text-gray-700 leading-relaxed">{description}</p>
    <slot name="text" />
  </div>
</section>
