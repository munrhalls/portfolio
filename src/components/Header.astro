---
---

<header class="bg-[#0A0A0A] border-b border-gray-800">
  <div class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="text-lg font-semibold text-white tracking-tight">Munrhalls</a>

    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      <a href="/about/" class="text-sm text-gray-300 hover:text-white transition-colors">About</a>
      <a href="/projects/" class="text-sm text-gray-300 hover:text-white transition-colors">Projects</a>
      <a href="/skills/" class="text-sm text-gray-300 hover:text-white transition-colors">Skills</a>
      <a href="/contact/" class="text-sm text-gray-300 hover:text-white transition-colors">Contact</a>
    </nav>

    <button
      type="button"
      id="mobile-menu-toggle"
      class="md:hidden p-2 text-gray-300 hover:text-white"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-800 bg-[#0A0A0A]">
    <nav class="flex flex-col px-4 py-2" aria-label="Mobile navigation">
      <a href="/about/" class="py-3 text-sm text-gray-300 hover:text-white transition-colors border-b border-gray-800">About</a>
      <a href="/projects/" class="py-3 text-sm text-gray-300 hover:text-white transition-colors border-b border-gray-800">Projects</a>
      <a href="/skills/" class="py-3 text-sm text-gray-300 hover:text-white transition-colors border-b border-gray-800">Skills</a>
      <a href="/contact/" class="py-3 text-sm text-gray-300 hover:text-white transition-colors">Contact</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function() {
    function setupMobileMenu() {
      var toggle = document.getElementById('mobile-menu-toggle');
      var menu = document.getElementById('mobile-menu');
      if (!toggle || !menu) return;

      var newToggle = toggle.cloneNode(true);
      toggle.parentNode.replaceChild(newToggle, toggle);

      newToggle.addEventListener('click', function() {
        var expanded = newToggle.getAttribute('aria-expanded') === 'true';
        newToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        menu.classList.toggle('hidden');
      });

      menu.classList.add('hidden');
      newToggle.setAttribute('aria-expanded', 'false');
    }

    document.addEventListener('astro:page-load', setupMobileMenu);
    setupMobileMenu();
  })();
</script>
