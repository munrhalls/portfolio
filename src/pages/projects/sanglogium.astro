---
import Base from '../../layouts/Base.astro';
import StickyNav from '../../components/StickyNav.astro';
import FeatureSection from '../../components/FeatureSection.astro';
import { Image } from 'astro:assets';

import heroImg from '../../assets/images/sanglogium/sanglogium-01.png';
import overviewImg from '../../assets/images/sanglogium/sanglogium-02.png';
import storefrontImg from '../../assets/images/sanglogium/sanglogium-03.png';
import searchImg from '../../assets/images/sanglogium/sanglogium-04.png';
import cartImg from '../../assets/images/sanglogium/sanglogium-05.png';
import checkoutImg from '../../assets/images/sanglogium/sanglogium-06.png';
import paymentImg from '../../assets/images/sanglogium/sanglogium-07.png';
import shippingImg from '../../assets/images/sanglogium/sanglogium-08.png';
import returnsImg from '../../assets/images/sanglogium/sanglogium-09.png';
import adminImg from '../../assets/images/sanglogium/sanglogium-10.png';
import marketingImg from '../../assets/images/sanglogium/sanglogium-11.png';
import testingImg from '../../assets/images/sanglogium/sanglogium-12.png';
import pipelineDiagram from '../../assets/images/sanglogium/images-pipeline-diagram.svg';

const navSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'storefront', label: 'Storefront' },
  { id: 'search', label: 'Search' },
  { id: 'cart', label: 'Cart' },
  { id: 'checkout', label: 'Checkout' },
  { id: 'payment', label: 'Payment' },
  { id: 'shipping', label: 'Shipping' },
  { id: 'returns', label: 'Returns' },
  { id: 'auth', label: 'Auth' },
  { id: 'admin', label: 'Admin' },
  { id: 'marketing', label: 'Marketing' },
  { id: 'images', label: 'Images' },
  { id: 'testing', label: 'Testing' },
];
---

<Base title="Sanglogium">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg"
  >
    Skip to main content
  </a>

  <section
    id="hero"
    class="relative min-h-[70vh] flex items-center justify-center scroll-mt-20"
  >
    <div class="absolute inset-0 -z-10">
      <Image
        src={heroImg}
        alt="Sanglogium hero screenshot"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    <div class="text-center text-white px-4">
      <h1 class="text-4xl md:text-6xl font-bold mb-4">Sanglogium</h1>
      <p class="text-lg md:text-xl max-w-2xl mx-auto">[Content TBD — hero tagline]</p>
    </div>
  </section>

  <StickyNav sections={navSections} />

  <FeatureSection
    id="overview"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <Image
      src={overviewImg}
      alt="Overview screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="storefront"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
    reversed
  >
    <Image
      src={storefrontImg}
      alt="Storefront screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="search"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <Image
      src={searchImg}
      alt="Search screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="cart"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
    reversed
  >
    <Image
      src={cartImg}
      alt="Cart screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="checkout"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <Image
      src={checkoutImg}
      alt="Checkout screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="payment"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
    reversed
  >
    <Image
      src={paymentImg}
      alt="Payment screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="shipping"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <Image
      src={shippingImg}
      alt="Shipping screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="returns"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
    reversed
  >
    <Image
      src={returnsImg}
      alt="Returns screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="auth"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <div slot="visual" class="overflow-x-auto">
      <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-sm" is:raw><code>function authenticateUser(token: string): boolean {
  const decoded = verifyToken(token);
  if (!decoded || decoded.exp < Date.now()) {
    return false;
  }
  return decoded.roles.includes('user');
}</code></pre>
    </div>
  </FeatureSection>

  <FeatureSection
    id="admin"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
    reversed
  >
    <Image
      src={adminImg}
      alt="Admin screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="marketing"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <Image
      src={marketingImg}
      alt="Marketing screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="images"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
    reversed
  >
    <Image
      src={pipelineDiagram}
      alt="Image pipeline diagram"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <FeatureSection
    id="testing"
    title="[Content TBD — section title]"
    description="[Content TBD — section description]"
  >
    <Image
      src={testingImg}
      alt="Testing screenshot"
      class="w-full rounded-lg shadow-md"
      slot="visual"
      loading="lazy"
    />
  </FeatureSection>

  <footer class="py-16 px-4 md:px-8 text-center border-t border-gray-200">
    <p class="text-gray-600 mb-4">[Content TBD — footer CTA]</p>
    <a
      href="/contact/"
      class="inline-block px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors"
    >
      Get in touch
    </a>
  </footer>

  <button
    id="back-to-top"
    type="button"
    class="fixed bottom-4 right-4 z-20 w-12 h-12 flex items-center justify-center rounded-full bg-gray-900 text-white shadow-lg opacity-0 pointer-events-none transition-opacity duration-300 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900"
    aria-label="Back to top"
  >
    ↑
  </button>

  <style>
    #sticky-nav.nav-visible {
      opacity: 1;
      pointer-events: auto;
    }

    #back-to-top.back-to-top-visible {
      opacity: 1;
      pointer-events: auto;
    }

    section.js-reveal-pending {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
  </style>

  <script>
    const observers: IntersectionObserver[] = [];

    function setup() {
      const hero = document.getElementById('hero');
      const nav = document.getElementById('sticky-nav');
      const backToTop = document.getElementById('back-to-top');
      const pills = document.querySelectorAll('.nav-pill');
      const contentSections = document.querySelectorAll('section:not(#hero)');

      if (!hero || !nav) return;

      // Nav visibility + back-to-top based on hero intersection
      const heroObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              nav.classList.remove('nav-visible');
              backToTop?.classList.remove('back-to-top-visible');
            } else {
              nav.classList.add('nav-visible');
              backToTop?.classList.add('back-to-top-visible');
            }
          });
        },
        { threshold: 0 }
      );
      heroObserver.observe(hero);
      observers.push(heroObserver);

      // Active section tracking
      const sectionIds = [
        'overview', 'storefront', 'search', 'cart', 'checkout',
        'payment', 'shipping', 'returns', 'auth', 'admin',
        'marketing', 'images', 'testing',
      ];

      const activeObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              pills.forEach((pill) => {
                const target = pill.getAttribute('data-target');
                if (target === `#${id}`) {
                  pill.setAttribute('aria-current', 'true');
                  pill.classList.add('bg-gray-900', 'text-white');
                  pill.classList.remove('bg-gray-100', 'text-gray-700');
                  // Mobile auto-scroll active pill into view
                  pill.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
                } else {
                  pill.setAttribute('aria-current', 'false');
                  pill.classList.remove('bg-gray-900', 'text-white');
                  pill.classList.add('bg-gray-100', 'text-gray-700');
                }
              });
            }
          });
        },
        { threshold: 0.1 }
      );

      sectionIds.forEach((id) => {
        const section = document.getElementById(id);
        if (section) activeObserver.observe(section);
      });
      observers.push(activeObserver);

      // Smooth scroll on pill click
      pills.forEach((pill) => {
        pill.addEventListener('click', (e) => {
          e.preventDefault();
          const target = pill.getAttribute('data-target');
          if (!target) return;
          const el = document.querySelector(target);
          if (el) {
            el.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });

      // Back-to-top click
      backToTop?.addEventListener('click', () => {
        hero.scrollIntoView({ behavior: 'smooth' });
      });

      // Scroll reveal (skip if reduced motion)
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!prefersReduced) {
        contentSections.forEach((section) => {
          if (section.id !== 'hero') {
            section.classList.add('js-reveal-pending');
          }
        });

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.remove('js-reveal-pending');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        contentSections.forEach((section) => {
          if (section.id !== 'hero') {
            revealObserver.observe(section);
          }
        });
        observers.push(revealObserver);
      }
    }

    function teardown() {
      observers.forEach((observer) => observer.disconnect());
      observers.length = 0;
    }

    document.addEventListener('astro:page-load', setup);
    document.addEventListener('astro:before-swap', teardown);

    // Fallback for non-ClientRouter (direct load)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }
  </script>
</Base>
