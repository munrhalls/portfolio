---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import MandorlaCanvas from '../components/MandorlaCanvas.astro';
import HomeBlock from '../components/HomeBlock.astro';
---

<Base title="Home">
  <!-- Desktop: 3×2 bento grid. Mobile: flex column -->
  <div class="flex-1 flex flex-col lg:grid lg:grid-cols-[1fr_1fr_1fr] lg:grid-rows-2">

    <!-- Row 1 -->
    <HomeBlock
      href="/about/"
      title="About"
      description="Full-stack developer"
      class="hidden lg:block lg:col-start-1 lg:row-start-1 lg:border-r lg:border-b border-gray-300"
    />

    <div class="aspect-square lg:aspect-auto lg:col-start-2 lg:row-span-2 lg:h-full">
      <MandorlaCanvas />
    </div>

    <HomeBlock
      href="/projects/sanglogium/"
      title="Sanglogium"
      description="E-commerce case study"
      class="hidden lg:block lg:col-start-3 lg:row-start-1 lg:border-l lg:border-b border-gray-300"
    />

    <!-- Row 2 -->
    <HomeBlock
      href="/skills/"
      title="Skills"
      description="Technologies & tools"
      class="hidden lg:block lg:col-start-1 lg:row-start-2 lg:border-r border-gray-300"
    />

    <HomeBlock
      href="/contact/"
      title="Contact"
      description="Get in touch"
      class="hidden lg:block lg:col-start-3 lg:row-start-2 lg:border-l border-gray-300"
    />

    <!-- Mobile sections -->
    <HomeBlock href="/about/" title="About" description="Full-stack developer" class="lg:hidden border-b border-gray-300" />
    <HomeBlock href="/projects/sanglogium/" title="Sanglogium" description="E-commerce case study" class="lg:hidden border-b border-gray-300" />
    <HomeBlock href="/skills/" title="Skills" description="Technologies & tools" class="lg:hidden" />
    <HomeBlock href="/contact/" title="Contact" description="Get in touch" class="lg:hidden border-t border-gray-300" />
  </div>

  <Footer slot="footer" />
</Base>
