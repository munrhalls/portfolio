---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import MandorlaCanvas from '../components/MandorlaCanvas.astro';
import HomeBlock from '../components/HomeBlock.astro';
---

<Base title="Home">
  <!-- Mobile: hero canvas + stacked links -->
  <div class="flex-1 flex flex-col lg:hidden">
    <div class="flex justify-center py-8">
      <div class="h-[30vh] w-[30vh]">
        <MandorlaCanvas />
      </div>
    </div>

    <div class="flex-1 flex flex-col">
      <HomeBlock href="/about/" title="About" description="Full-stack developer" class="p-4 border-t border-b border-gray-300" />
      <HomeBlock href="/projects/sanglogium/" title="Sanglogium" description="E-commerce case study" class="p-4 border-b border-gray-300" />
      <HomeBlock href="/skills/" title="Skills" description="Technologies & tools" class="p-4 border-b border-gray-300" />
      <HomeBlock href="/contact/" title="Contact" description="Get in touch" class="p-4 flex-1 border-b border-gray-300" />
    </div>
  </div>

  <!-- Desktop: 3×2 bento grid -->
  <div class="flex-1 hidden lg:grid lg:grid-cols-[1fr_1fr_1fr] lg:grid-rows-2">
    <HomeBlock
      href="/about/"
      title="About"
      description="Full-stack developer"
      class="lg:col-start-1 lg:row-start-1 lg:border-r lg:border-b border-gray-300"
    />

    <div class="lg:col-start-2 lg:row-span-2 lg:h-full">
      <MandorlaCanvas />
    </div>

    <HomeBlock
      href="/projects/sanglogium/"
      title="Sanglogium"
      description="E-commerce case study"
      class="lg:col-start-3 lg:row-start-1 lg:border-l lg:border-b border-gray-300"
    />

    <HomeBlock
      href="/skills/"
      title="Skills"
      description="Technologies & tools"
      class="lg:col-start-1 lg:row-start-2 lg:border-r border-gray-300"
    />

    <HomeBlock
      href="/contact/"
      title="Contact"
      description="Get in touch"
      class="lg:col-start-3 lg:row-start-2 lg:border-l border-gray-300"
    />
  </div>

  <Footer slot="footer" />
</Base>
