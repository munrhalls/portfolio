import img03 from '../assets/images/sanglogium/sanglogium-03.png';
import img04 from '../assets/images/sanglogium/sanglogium-04.png';
import img05 from '../assets/images/sanglogium/sanglogium-05.png';
import img06 from '../assets/images/sanglogium/sanglogium-06.png';
import img07 from '../assets/images/sanglogium/sanglogium-07.png';
import img08 from '../assets/images/sanglogium/sanglogium-08.png';
import img09 from '../assets/images/sanglogium/sanglogium-09.png';
import img10 from '../assets/images/sanglogium/sanglogium-10.png';
import img11 from '../assets/images/sanglogium/sanglogium-11.png';
import img12 from '../assets/images/sanglogium/sanglogium-12.png';

import basketPage from '../../assets/checkout-system/slices/basket-page.png';
import address from '../../assets/checkout-system/slices/address.png';
import shipping from '../../assets/checkout-system/slices/shipping.png';
import payment from '../../assets/checkout-system/slices/payment.png';
import returnPage from '../../assets/checkout-system/slices/return-page.png';

// Code snippets — stored as consts to avoid Astro parsing { } inside <pre><code>
const codePaymentRederive = `// Server re-derives grand total from live Sanity data — client total is untrusted
const products = await getBackendClient().fetch(
  groq\`*[_type == "product" && _id in $ids]{ _id, price_data { unit_amount } }\`,
  { ids }
)
let subtotal = 0
for (const item of session.basket) {
  const product = products.find(p => p._id === item.productId)
  const unitPrice = product?.price_data?.unit_amount
  if (!unitPrice || !Number.isFinite(unitPrice)) {
    return NextResponse.json({ error: 'Invalid price' }, { status: 400 })
  }
  subtotal += unitPrice * item.quantity
}
const computedGrandTotal = Math.round(subtotal + session.shippingCost)`;

const codePaymentGuards = `if (!session.basket?.length) redirect("/basket")
if (session.basket.some(i => !Number.isInteger(i.quantity) || i.quantity < 1))
  redirect("/basket?error=invalid_basket")
if (!session.address) redirect("/checkout/address")
if (session.shippingCost === undefined || session.shippingCost === null)
  redirect("/checkout/shipping")
for (const item of session.basket) {
  if (item.quantity > MAX_QUANTITY_PER_ITEM)
    redirect(\`/basket?error=excessive_quantity&id=\${item.productId}\`)
}`;

const codeParcelCalc = `const MAX_WEIGHT_G = 25000    // 25kg max per package
const MAX_VOLUME_CM3 = 99000  // 99,000 cm³ max per package

const parcelsByWeight = Math.ceil(totalWeight / MAX_WEIGHT_G)
const parcelsByVolume = Math.ceil(totalVolume / MAX_VOLUME_CM3)
const numParcels = Math.max(parcelsByWeight, parcelsByVolume, 1)
// auto-splits into multiple parcels when basket exceeds courier limits`;

const codeAddressValidation = `const ALLOWED_GRANULARITY = new Set(["PREMISE", "SUB_PREMISE"])
// Google verdict: inputGranularity, validationGranularity, geocodeGranularity
// addressComplete, hasReplacedComponents, hasSpellCorrectedComponents
// → ACCEPT: save to session, redirect to shipping
// → FIX:    return validation errors to client
// → CONFIRM: show corrected address for user confirmation`;

const codeADR = `Pattern 1 — Standard items: Pure OCC at payment
  No inventory held during checkout. At payment: atomic Sanity transaction
  checks stock > 0 and decrements in a single operation (OCC).
  If check fails (race): "Another customer just purchased the last unit."
  Rationale: ~81% cart abandonment in luxury/audio means pessimistic locking
  starves real buyers. Collision probability negligible vs starvation risk.

Pattern 2 — Rare/flagship ($3k+, qty=1): Soft Reservation via Redis TTL
  Redis key: soft-reserve:{productId}:{sessionId}  TTL = 10 minutes
  On completion: promote to hard Sanity decrement, delete Redis key.
  On TTL expiry: auto-delete, item becomes available again.
  Industry pattern: Fluent Commerce, Broadleaf, Microsoft Dynamics 365.`;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Jan Pilik — Full-Stack Developer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <!-- Prevent flash of wrong theme -->
  <script>(function(){var t=localStorage.getItem('theme');if(t==='dark')document.documentElement.setAttribute('data-theme','dark');})()</script>
  <style>
    /* =====================================================
       TOKENS
    ===================================================== */
    :root {
      /* Light mode — default */
      --bg:                 #f5f4f1;
      --surface:            #ffffff;
      --surface-2:          #edeae4;
      --border:             #d8d4ce;
      --text:               #1a1917;
      --text-muted:         #6b6560;
      --gold:               #9a6700;
      --code-inline-bg:     #edeae4;
      --code-inline-color:  #7c4400;
      --code-inline-border: #cdc8c0;
      --radius:             6px;
      --font-body:          'Inter', system-ui, -apple-system, sans-serif;
      --font-mono:          'JetBrains Mono', 'Fira Code', Consolas, monospace;
    }

    [data-theme="dark"] {
      --bg:                 #0d0d0d;
      --surface:            #161616;
      --surface-2:          #1e1e1e;
      --border:             #2a2a2a;
      --text:               #e8e8e8;
      --text-muted:         #888;
      --gold:               #c8940a;
      --code-inline-bg:     #1a1a1a;
      --code-inline-color:  #e6b84f;
      --code-inline-border: #333;
    }

    /* =====================================================
       RESET + BASE
    ===================================================== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { background: var(--bg); }

    body {
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.5;
      max-width: 320px;
      margin: 0 auto;
      padding: 12px;
      background: var(--bg);
      color: var(--text);
    }

    ul, ol { padding-left: 16px; }
    a { color: var(--gold); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { display: block; max-width: 100%; }
    figure { margin: 0; }

    /* =====================================================
       SECTION 1: HERO
    ===================================================== */
    #hero {
      padding: 16px 0 20px;
    }

    .hero-intro {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .avatar-circle {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--surface-2);
      border: 2px solid var(--border);
      flex-shrink: 0;
    }

    .hero-right {
      flex: 1;
      min-width: 0;
    }

    .hero-bio {
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
    }

    .hero-selling-points {
      margin-top: 8px;
      list-style: none;
      padding: 7px 10px 7px 10px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    .hero-selling-points li {
      position: relative;
      padding-left: 14px;
      margin-bottom: 4px;
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.4;
    }

    .hero-selling-points li:last-child { margin-bottom: 0; }

    .hero-selling-points li::before {
      content: '›';
      position: absolute;
      left: 0;
      color: var(--gold);
      font-weight: 700;
    }

    .hero-callout {
      margin-top: 14px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .hero-link {
      display: inline-block;
      margin-top: 4px;
      font-size: 16px;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: -0.01em;
    }

    /* =====================================================
       PANEL CONTENT
       Styles for [role="tabpanel"] slot content —
       authored in this file so scoped here, not in component.
    ===================================================== */
    [role="tabpanel"] h3 {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 8px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
    }

    [role="tabpanel"] h4 {
      font-size: 11px;
      font-weight: 600;
      color: var(--text);
      margin-top: 12px;
      margin-bottom: 4px;
    }

    [role="tabpanel"] p {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 6px;
      line-height: 1.5;
    }

    [role="tabpanel"] ul,
    [role="tabpanel"] ol {
      padding-left: 16px;
      margin-bottom: 6px;
    }

    [role="tabpanel"] li {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 4px;
      line-height: 1.4;
    }

    [role="tabpanel"] strong {
      color: var(--text);
      font-weight: 600;
    }

    [role="tabpanel"] pre {
      font-family: var(--font-mono);
      font-size: 10px;
      background: #111;
      border: 1px solid var(--border);
      border-left: 2px solid var(--gold);
      padding: 8px;
      overflow-x: auto;
      margin: 6px 0;
      white-space: pre-wrap;
      word-break: break-word;
      border-radius: 0 4px 4px 0;
      color: #c9d1d9;
      line-height: 1.55;
    }

    [role="tabpanel"] code {
      font-family: var(--font-mono);
      font-size: 10px;
      background: var(--code-inline-bg);
      color: var(--code-inline-color);
      padding: 1px 4px;
      border-radius: 3px;
      border: 1px solid var(--code-inline-border);
    }

    [role="tabpanel"] pre code {
      background: none;
      padding: 0;
      border: none;
      color: inherit;
      font-size: inherit;
    }

    [role="tabpanel"] figure {
      margin: 8px 0;
    }

    [role="tabpanel"] img {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 4px;
      display: block;
    }

    [role="tabpanel"] figcaption {
      font-size: 10px;
      color: var(--text-muted);
      margin-top: 4px;
      text-align: center;
    }

    [role="tabpanel"] a {
      font-size: 11px;
      color: var(--gold);
      display: inline-block;
      margin-top: 4px;
      text-decoration: none;
    }

    [role="tabpanel"] a:hover { text-decoration: underline; }

    /* =====================================================
       FOOTER
    ===================================================== */
    #page-footer {
      margin-top: 24px;
      padding: 12px 0;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 11px;
      color: var(--text-muted);
      letter-spacing: 0.04em;
    }

    /* =====================================================
       THEME TOGGLE — all viewports (fixed corner button)
    ===================================================== */
    #theme-toggle {
      position: fixed;
      top: 14px;
      right: 14px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text-muted);
      cursor: pointer;
      font-size: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 100;
      transition: color 0.2s, border-color 0.2s;
      line-height: 1;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }
    #theme-toggle:hover {
      color: var(--gold);
      border-color: var(--gold);
    }

    /* =====================================================
       DESKTOP — 768px+
    ===================================================== */
    @media (min-width: 768px) {
      body {
        max-width: 940px;
        padding: 0 48px;
        font-size: 15px;
      }

      /* Hero — 2-column: bio left, project callout right */
      #hero {
        display: grid;
        grid-template-columns: 3fr 2fr;
        grid-template-rows: auto auto;
        column-gap: 56px;
        padding: 52px 0 52px;
        border-bottom: 1px solid var(--border);
      }
      .hero-intro {
        grid-column: 1;
        grid-row: 1 / 3;
        align-self: center;
        gap: 20px;
        align-items: center;
      }
      .avatar-circle { width: 88px; height: 88px; }
      .hero-bio { font-size: 16px; line-height: 1.55; }
      .hero-selling-points {
        font-size: 14px;
        padding: 10px 14px;
        margin-top: 14px;
      }
      .hero-callout {
        grid-column: 2;
        grid-row: 1;
        margin-top: 0;
        text-align: right;
        font-size: 10px;
        align-self: end;
        white-space: nowrap;
      }
      .hero-link {
        grid-column: 2;
        grid-row: 2;
        text-align: right;
        font-size: 28px;
        margin-top: 4px;
        align-self: start;
      }

      /* Panel content */
      [role="tabpanel"] h3 { font-size: 12px; margin-bottom: 10px; padding-bottom: 8px; }
      [role="tabpanel"] h4 { font-size: 12px; margin-top: 16px; margin-bottom: 5px; }
      [role="tabpanel"] p  { font-size: 13px; margin-bottom: 8px; }
      [role="tabpanel"] li { font-size: 13px; margin-bottom: 5px; }
      [role="tabpanel"] pre { font-size: 11px; padding: 10px 12px; }
      [role="tabpanel"] code { font-size: 11px; }
      [role="tabpanel"] figcaption { font-size: 11px; }
      [role="tabpanel"] a { font-size: 12px; }

      /* Footer */
      #page-footer { margin-top: 56px; padding: 20px 0; font-size: 12px; }
    }
  </style>
</head>
